generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model WeatherQuery {
  id          Int                  @id @default(autoincrement())
  location    String
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime             @default(now())
  results     WeatherQueryResult[]
}

model WeatherQueryResult {
  id            Int          @id @default(autoincrement())
  queryId       Int
  query         WeatherQuery @relation(fields: [queryId], references: [id], onDelete: Cascade)
  date          DateTime
  temperature   Float
  minTemp       Float?
  maxTemp       Float?
  condition     String
  icon          String?
  humidity      Int?
  windKph       Float?
}
