generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model WeatherSearch {
  id          Int      @id @default(autoincrement())
  city        String
  country     String
  temperature Float
  condition   String
  humidity    Int
  windKph     Float
  searchedAt  DateTime @default(now())
}
